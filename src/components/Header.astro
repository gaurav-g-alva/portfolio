---
import { siteConfig } from "../config";
const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "/index.html";
const isBlog = Astro.url.pathname.startsWith("/blog");
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
const hasCertifications = siteConfig.certifications && siteConfig.certifications.length > 0;
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 hidden md:block transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-8 py-4">
    <ul class="flex items-center gap-8 justify-center">
      <li>
        <a
          href={isHome ? "#about" : "/#about"}
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          About
        </a>
      </li>
      {
        hasProjects && (
          <li>
            <a
              href={isHome ? "#projects" : "/#projects"}
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              Projects
            </a>
          </li>
        )
      }
      {
        hasExperience && (
          <li>
            <a
              href={isHome ? "#experience" : "/#experience"}
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              Experience
            </a>
          </li>
        )
      }
      {
        hasEducation && (
          <li>
            <a
              href={isHome ? "#education" : "/#education"}
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              Education
            </a>
          </li>
        )
      }
      {
        hasCertifications && (
          <li>
            <a
              href={isHome ? "#certifications" : "/#certifications"}
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              Certifications
            </a>
          </li>
        )
      }
      <li>
        <a
          href="/blog"
          class={`transition-colors font-medium ${isBlog ? "text-[var(--accent-color)] font-semibold" : "text-gray-700 hover:text-black"}`}
          style={`--accent-color: ${siteConfig.accentColor}`}
        >
          Blog
        </a>
      </li>
      <!-- <li>
        <a
          href="/images/Gaurav_Resume_R7.pdf"
          download="Gaurav-G-Alva-Resume.pdf"
          class="px-4 py-2 rounded-md text-white font-medium transition-colors duration-300"
          style={`background-color: ${siteConfig.accentColor}`}
        >
          Resume
        </a>
      </li> -->
      {
        siteConfig.resumeUrl && (
          <li>
            <a
              href={siteConfig.resumeUrl}
              download
              class="inline-flex items-center gap-x-1.5 px-3 py-1.5 border border-[var(--accent-color)] text-[var(--accent-color)] rounded-lg font-mono text-sm font-semibold hover:bg-[var(--accent-color)] hover:text-white transition-all duration-300 shadow-sm"
              style={`--accent-color: ${siteConfig.accentColor}`}
              id="header-resume-download"
            >
              Resume
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="w-3.5 h-3.5"
              >
                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                <path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2 -2v-2" />
                <path d="M7 11l5 5l5 -5" />
                <path d="M12 4l0 12" />
              </svg>
            </a>
          </li>
        )
      }
    </ul>
  </nav>
</header>

<script>
  window.addEventListener("scroll", () => {
    const header = document.getElementById("header");
    if (window.scrollY > 100) {
      header?.classList.add("bg-white/80", "backdrop-blur-sm");
    } else {
      header?.classList.remove("bg-white/80", "backdrop-blur-sm");
    }
  });
</script>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
