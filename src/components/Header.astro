---
import { siteConfig } from "../config";
const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "/index.html";
const isBlog = Astro.url.pathname.startsWith("/blog");
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
const hasCertifications = siteConfig.certifications && siteConfig.certifications.length > 0;
---

<!-- Desktop Header (visible on medium screens and up) -->
<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 hidden md:block transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-8 py-4">
    <ul class="flex items-center gap-8 justify-center">
      <li>
        <a
          href={isHome ? "#about" : "/#about"}
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          About
        </a>
      </li>
      {
        hasProjects && (
          <li>
            <a
              href={isHome ? "#projects" : "/#projects"}
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              Projects
            </a>
          </li>
        )
      }
      {
        hasExperience && (
          <li>
            <a
              href={isHome ? "#experience" : "/#experience"}
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              Experience
            </a>
          </li>
        )
      }
      {
        hasEducation && (
          <li>
            <a
              href={isHome ? "#education" : "/#education"}
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              Education
            </a>
          </li>
        )
      }
      {
        hasCertifications && (
          <li>
            <a
              href={isHome ? "#certifications" : "/#certifications"}
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              Certifications
            </a>
          </li>
        )
      }
      <li>
        <a
          href="/blog"
          class={`transition-colors font-medium ${isBlog ? "text-[var(--accent-color)] font-semibold" : "text-gray-700 hover:text-black"}`}
          style={`--accent-color: ${siteConfig.accentColor}`}
        >
          Blog
        </a>
      </li>
      {
        siteConfig.resumeUrl && (
          <li>
            <a
              href={siteConfig.resumeUrl}
              download
              class="inline-flex items-center gap-x-1.5 px-3 py-1.5 border border-[var(--accent-color)] text-[var(--accent-color)] rounded-lg font-mono text-sm font-semibold hover:bg-[var(--accent-color)] hover:text-white transition-all duration-300 shadow-sm"
              style={`--accent-color: ${siteConfig.accentColor}`}
              id="header-resume-download"
            >
              Resume
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="w-3.5 h-3.5"
              >
                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                <path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2 -2v-2" />
                <path d="M7 11l5 5l5 -5" />
                <path d="M12 4l0 12" />
              </svg>
            </a>
          </li>
        )
      }
    </ul>
  </nav>
</header>

<!-- Mobile Header Bar (visible on screens smaller than md) -->
<div 
  id="mobile-header" 
  class="fixed top-0 left-0 right-0 z-50 md:hidden bg-white/80 backdrop-blur-md border-b border-gray-100 px-6 py-4 flex items-center justify-between transition-all duration-300"
>
  <a href={isHome ? "#hero" : "/"} class="text-lg font-bold tracking-tight text-gray-800 hover:text-[var(--accent-color)] transition-colors" style={`--accent-color: ${siteConfig.accentColor}`}>
    {siteConfig.name}
  </a>
  <button 
    id="mobile-menu-toggle" 
    class="text-gray-700 hover:text-black focus:outline-none p-1 transition-colors duration-200" 
    aria-label="Toggle Menu"
  >
    <!-- Hamburger Icon -->
    <svg id="hamburger-icon" class="w-6 h-6 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
    <!-- Close Icon (Hidden by default) -->
    <svg id="close-icon" class="w-6 h-6 hidden transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
</div>

<!-- Mobile Menu Drawer (visible on screens smaller than md) -->
<div 
  id="mobile-drawer" 
  class="fixed inset-0 z-40 md:hidden bg-white/98 backdrop-blur-lg transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col justify-center px-10 pt-24 pb-12"
>
  <nav class="flex flex-col gap-6 text-xl font-bold text-gray-800">
    <a href={isHome ? "#about" : "/#about"} class="mobile-nav-link hover:text-[var(--accent-color)] transition-colors py-2 border-b border-gray-100/60" style={`--accent-color: ${siteConfig.accentColor}`}>
      About
    </a>
    {hasProjects && (
      <a href={isHome ? "#projects" : "/#projects"} class="mobile-nav-link hover:text-[var(--accent-color)] transition-colors py-2 border-b border-gray-100/60" style={`--accent-color: ${siteConfig.accentColor}`}>
        Projects
      </a>
    )}
    {hasExperience && (
      <a href={isHome ? "#experience" : "/#experience"} class="mobile-nav-link hover:text-[var(--accent-color)] transition-colors py-2 border-b border-gray-100/60" style={`--accent-color: ${siteConfig.accentColor}`}>
        Experience
      </a>
    )}
    {hasEducation && (
      <a href={isHome ? "#education" : "/#education"} class="mobile-nav-link hover:text-[var(--accent-color)] transition-colors py-2 border-b border-gray-100/60" style={`--accent-color: ${siteConfig.accentColor}`}>
        Education
      </a>
    )}
    {hasCertifications && (
      <a href={isHome ? "#certifications" : "/#certifications"} class="mobile-nav-link hover:text-[var(--accent-color)] transition-colors py-2 border-b border-gray-100/60" style={`--accent-color: ${siteConfig.accentColor}`}>
        Certifications
      </a>
    )}
    <a href="/blog" class={`mobile-nav-link py-2 border-b border-gray-100/60 transition-colors ${isBlog ? "text-[var(--accent-color)]" : "hover:text-[var(--accent-color)]"}`} style={`--accent-color: ${siteConfig.accentColor}`}>
      Blog
    </a>
    
    {siteConfig.resumeUrl && (
      <a
        href={siteConfig.resumeUrl}
        download
        class="mt-6 w-full text-center py-3.5 border-2 border-[var(--accent-color)] text-[var(--accent-color)] rounded-xl font-mono text-base font-bold hover:bg-[var(--accent-color)] hover:text-white transition-all duration-300 shadow-sm"
        style={`--accent-color: ${siteConfig.accentColor}`}
        id="mobile-resume-download"
      >
        Resume
      </a>
    )}
  </nav>
</div>

<script>
  // Desktop header scroll behavior
  window.addEventListener("scroll", () => {
    const header = document.getElementById("header");
    const mobileHeader = document.getElementById("mobile-header");
    
    if (window.scrollY > 50) {
      header?.classList.add("bg-white/80", "backdrop-blur-sm", "shadow-sm", "border-b", "border-gray-100/50");
      mobileHeader?.classList.add("shadow-sm", "border-b", "border-gray-100/50");
    } else {
      header?.classList.remove("bg-white/80", "backdrop-blur-sm", "shadow-sm", "border-b", "border-gray-100/50");
      mobileHeader?.classList.remove("shadow-sm", "border-b", "border-gray-100/50");
    }
  });

  // Mobile menu toggle logic
  const toggleBtn = document.getElementById("mobile-menu-toggle");
  const drawer = document.getElementById("mobile-drawer");
  const hamburger = document.getElementById("hamburger-icon");
  const closeIcon = document.getElementById("close-icon");
  const links = document.querySelectorAll(".mobile-nav-link");

  let isOpen = false;

  function toggleMenu() {
    isOpen = !isOpen;
    if (isOpen) {
      drawer?.classList.remove("translate-x-full");
      drawer?.classList.add("translate-x-0");
      hamburger?.classList.add("hidden");
      closeIcon?.classList.remove("hidden");
      document.body.classList.add("overflow-hidden");
    } else {
      drawer?.classList.remove("translate-x-0");
      drawer?.classList.add("translate-x-full");
      hamburger?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      document.body.classList.remove("overflow-hidden");
    }
  }

  toggleBtn?.addEventListener("click", toggleMenu);

  links.forEach(link => {
    link.addEventListener("click", () => {
      if (isOpen) toggleMenu();
    });
  });
</script>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
