---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { siteConfig } from "../../config";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import "../../styles/global.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await post.render();

const formatDate = (date: Date) => {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};

const canonicalURL = new URL(Astro.url.pathname, siteConfig.siteUrl);
const schemaData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  "author": {
    "@type": "Person",
    "name": post.data.author || siteConfig.name
  },
  "url": canonicalURL.toString(),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL.toString()
  }
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={post.data.description} />
    <meta name="robots" content="index, follow" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${post.data.title} - ${siteConfig.name}`} />
    <meta property="og:description" content={post.data.description} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${post.data.title} - ${siteConfig.name}`} />
    <meta property="twitter:description" content={post.data.description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <title>{post.data.title} - {siteConfig.name}</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaData)} />
  </head>
  <body class="bg-white" style={`--accent-color: ${siteConfig.accentColor}`}>
    <Header />

    <main class="relative isolate overflow-hidden min-h-screen pt-24 pb-16">
      <!-- Gradient overlay -->
      <div
        class="absolute inset-0 -z-10"
        style={`background: radial-gradient(ellipse 800px 600px at 50% -100px, ${siteConfig.accentColor}15 0%, ${siteConfig.accentColor}08 30%, ${siteConfig.accentColor}03 60%, white 100%)`}
      >
      </div>

      <div class="mx-auto max-w-4xl px-6 lg:px-8 mt-8 md:mt-12">
        <!-- Back Button -->
        <a
          href="/blog"
          id="back-to-blog"
          class="inline-flex items-center gap-x-2 text-sm font-bold text-gray-500 hover:text-[var(--accent-color)] transition-colors duration-200 group mb-8"
        >
          <svg
            class="w-4 h-4 transition-transform duration-200 group-hover:-translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M15 19l-7-7 7-7"
            />
          </svg>
          Back to all articles
        </a>

        <!-- Article Header -->
        <header class="border-b border-gray-100 pb-8">
          <div class="flex items-center gap-x-4 text-sm font-mono text-gray-500 mb-4">
            <time datetime={post.data.pubDate.toISOString()}>
              {formatDate(post.data.pubDate)}
            </time>
            {post.data.author && (
              <span class="before:content-['•'] before:mr-2">
                By {post.data.author}
              </span>
            )}
          </div>
          
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-gray-900 leading-tight">
            {post.data.title}
          </h1>

          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-6">
              {post.data.tags.map((tag) => (
                <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-xs sm:text-sm font-medium font-mono">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </header>

        <!-- Article Body -->
        <div class="blog-content mt-8">
          <Content />
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  /* Premium typography rules for markdown blog posts */
  .blog-content {
    font-family: 'IBM Plex Mono', monospace; /* Keep overall aesthetic, but style body for readability */
  }

  .blog-content :global(p) {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    font-size: 1.05rem;
    line-height: 1.75;
    color: #374151; /* gray-700 */
  }

  .blog-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    font-size: 1.75rem;
    font-weight: 700;
    color: #111827; /* gray-900 */
    border-left: 4px solid var(--accent-color);
    padding-left: 0.75rem;
  }

  .blog-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.35rem;
    font-weight: 700;
    color: #1f2937; /* gray-800 */
  }

  .blog-content :global(ul) {
    list-style-type: square;
    padding-left: 1.75rem;
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .blog-content :global(ol) {
    list-style-type: decimal;
    padding-left: 1.75rem;
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .blog-content :global(li) {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
    line-height: 1.75;
    color: #374151;
  }

  .blog-content :global(pre) {
    background-color: #f8fafc; /* slate-50 */
    border: 1px solid #e2e8f0; /* slate-200 */
    border-radius: 12px;
    padding: 1.25rem;
    overflow-x: auto;
    margin-top: 2rem;
    margin-bottom: 2rem;
    font-size: 0.9rem;
    line-height: 1.6;
    box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
  }

  .blog-content :global(code) {
    font-family: 'IBM Plex Mono', monospace;
    background-color: #f1f5f9; /* slate-100 */
    color: #0f172a; /* slate-900 */
    padding: 0.15rem 0.4rem;
    border-radius: 6px;
    font-size: 0.9em;
    font-weight: 500;
  }

  .blog-content :global(pre code) {
    background-color: transparent;
    color: inherit;
    padding: 0;
    font-size: inherit;
    border-radius: 0;
    font-weight: normal;
  }

  .blog-content :global(blockquote) {
    border-left: 4px solid var(--accent-color);
    background-color: #f8fafc;
    padding: 1rem 1.5rem;
    font-style: italic;
    color: #475569; /* slate-600 */
    margin-top: 2rem;
    margin-bottom: 2rem;
    border-radius: 0 12px 12px 0;
  }

  .blog-content :global(a) {
    color: var(--accent-color);
    text-decoration: underline;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .blog-content :global(a:hover) {
    color: #111827;
  }

  .blog-content :global(hr) {
    border: 0;
    border-top: 1px solid #e2e8f0;
    margin: 2.5rem 0;
  }
</style>
