---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { siteConfig } from "../../config";
import { getCollection } from "astro:content";
import "../../styles/global.css";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatDate = (date: Date) => {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};

const canonicalURL = new URL(Astro.url.pathname, siteConfig.siteUrl);
const blogDescription = `Articles and insights by ${siteConfig.name} on technology, development, and more.`;
const schemaData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${siteConfig.name} - Blog`,
  "description": blogDescription,
  "url": canonicalURL.toString(),
  "publisher": {
    "@type": "Person",
    "name": siteConfig.name
  }
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={blogDescription} />
    <meta name="robots" content="index, follow" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${siteConfig.name} - Blog`} />
    <meta property="og:description" content={blogDescription} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${siteConfig.name} - Blog`} />
    <meta property="twitter:description" content={blogDescription} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <title>{siteConfig.name} - Blog</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaData)} />
  </head>
  <body class="bg-white" style={`--accent-color: ${siteConfig.accentColor}`}>
    <Header />
    
    <main class="relative isolate overflow-hidden min-h-screen pt-24 pb-16">
      <!-- Gradient overlay -->
      <div
        class="absolute inset-0 -z-10"
        style={`background: radial-gradient(ellipse 800px 600px at 50% -100px, ${siteConfig.accentColor}20 0%, ${siteConfig.accentColor}10 30%, ${siteConfig.accentColor}05 60%, white 100%)`}
      >
      </div>

      <div class="mx-auto max-w-6xl px-6 lg:px-8 mt-8 md:mt-16">
        <!-- Section Header -->
        <div class="border-b border-gray-100 pb-10">
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-gray-900">
            The Blog
          </h1>
          <div
            class="w-[100px] h-[5px] mt-4 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          >
          </div>
          <p class="mt-6 text-lg sm:text-xl text-gray-600 max-w-2xl leading-relaxed">
            Thoughts, deep-dives, and tutorials about software development, design patterns, and full-stack architecture.
          </p>
        </div>

        <!-- Blog Posts Grid -->
        {
          sortedPosts.length > 0 ? (
            <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
              {sortedPosts.map((post) => (
                <article class="group flex flex-col justify-between p-6 bg-gray-50 rounded-2xl border border-gray-200 hover:bg-white hover:shadow-xl hover:border-gray-300 hover:-translate-y-1 transition-all duration-300">
                  <div class="space-y-4">
                    <!-- Date & Author -->
                    <div class="flex items-center gap-x-4 text-xs font-mono text-gray-500">
                      <time datetime={post.data.pubDate.toISOString()}>
                        {formatDate(post.data.pubDate)}
                      </time>
                      {post.data.author && (
                        <span class="before:content-['•'] before:mr-2">
                          {post.data.author}
                        </span>
                      )}
                    </div>

                    <!-- Title -->
                    <div class="relative group">
                      <h3 class="text-xl font-bold text-gray-900 leading-snug group-hover:text-[var(--accent-color)] transition-colors duration-200">
                        <a href={`/blog/${post.slug}`} id={`blog-post-link-${post.slug}`}>
                          <span class="absolute inset-0" />
                          {post.data.title}
                        </a>
                      </h3>
                    </div>

                    <!-- Description -->
                    <p class="text-sm sm:text-base text-gray-600 leading-relaxed line-clamp-3">
                      {post.data.description}
                    </p>
                  </div>

                  <!-- Footer: Tags & Read Link -->
                  <div class="mt-6 pt-4 border-t border-gray-100 flex flex-col gap-3">
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1.5">
                        {post.data.tags.map((tag) => (
                          <span class="px-2 py-0.5 bg-gray-200 text-gray-700 rounded text-xs font-medium font-mono">
                            #{tag}
                          </span>
                        ))}
                      </div>
                    )}
                    <div class="flex items-center text-sm font-bold text-[var(--accent-color)] mt-2 group-hover:underline">
                      Read post
                      <svg
                        class="ml-1 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2.5"
                          d="M9 5l7 7-7 7"
                        />
                      </svg>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="mt-16 text-center py-12 bg-gray-50 rounded-2xl border border-dashed border-gray-300">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="mx-auto h-12 w-12 text-gray-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
                />
              </svg>
              <h3 class="mt-4 text-lg font-bold text-gray-900">No blog posts found</h3>
              <p class="mt-2 text-sm text-gray-500">
                Check back later or log in to the admin panel to write your first post!
              </p>
            </div>
          )
        }
      </div>
    </main>

    <Footer />
  </body>
</html>
